---
import ThemeToggle from '../islands/ThemeToggle.svelte';
import ResearcherToggle from '../islands/ResearcherToggle.svelte';
import CommandPalette from '../islands/CommandPalette.svelte';
import { url } from '../lib/url';
const { pathname } = Astro.url;
const nav = [
  { href: url('/browse/'), label: 'Browse' },
  { href: url('/graph/'), label: 'Graph' },
  { href: url('/timeline/'), label: 'Timeline' },
  { href: url('/map/'), label: 'Map' },
  { href: url('/sources/'), label: 'Sources' },
];
---
<header class="nav" transition:persist>
  <div class="nav-inner">
    <a class="brand" href={url('/')}>
      <span class="brand-name">REALMS</span>
      <span class="brand-sub ui">archive of entities</span>
    </a>
    <nav class="nav-links ui" aria-label="Primary">
      {nav.map(item => (
        <a
          href={item.href}
          class:list={['nav-link', { active: pathname.startsWith(item.href) }]}
        >
          {item.label}
        </a>
      ))}
    </nav>
    <div class="nav-tools">
      <button id="cmdk-open" class="nav-btn ui" title="Command palette (⌘K)" aria-label="Open command palette">
        <span class="kbd">⌘K</span>
      </button>
      <ThemeToggle client:idle />
      <ResearcherToggle client:idle />
    </div>
  </div>
</header>
<CommandPalette client:idle />
<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg) 92%, transparent);
    backdrop-filter: blur(8px) saturate(140%);
    -webkit-backdrop-filter: blur(8px) saturate(140%);
    border-bottom: 1px solid var(--rule);
  }
  .nav-inner {
    max-width: var(--page-max);
    margin: 0 auto;
    padding: var(--sp-3) var(--sp-5);
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--sp-5);
  }
  .brand {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    line-height: 1;
  }
  .brand-name {
    font-family: var(--font-serif);
    font-weight: 550;
    font-variation-settings: 'opsz' 72, 'SOFT' 50, 'WONK' 1;
    letter-spacing: -0.02em;
    font-size: var(--fs-lg);
    color: var(--ink);
  }
  .brand-sub {
    font-size: var(--fs-xs);
    color: var(--ink-faint);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-top: 2px;
  }
  .nav-links {
    display: flex;
    gap: var(--sp-5);
    justify-content: center;
    font-size: var(--fs-sm);
  }
  .nav-link {
    color: var(--ink-dim);
    text-decoration: none;
    padding: var(--sp-2) 0;
    position: relative;
    transition: color var(--dur-fast) var(--ease);
  }
  .nav-link:hover { color: var(--ink); }
  .nav-link.active {
    color: var(--ink);
  }
  .nav-link.active::after {
    content: '';
    position: absolute;
    inset: auto 0 -1px 0;
    height: 2px;
    background: var(--accent);
  }
  .nav-tools {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
  }
  .nav-btn {
    background: transparent;
    border: 1px solid var(--rule);
    color: var(--ink-dim);
    padding: 4px 10px;
    border-radius: var(--r-md);
    cursor: pointer;
    font-size: var(--fs-sm);
    font-family: var(--font-sans);
    transition: all var(--dur-fast) var(--ease);
  }
  .nav-btn:hover {
    color: var(--ink);
    border-color: var(--ink-faint);
  }
  .kbd {
    font-family: var(--font-mono);
    font-size: 0.85em;
  }
  @media (max-width: 720px) {
    .nav-links { display: none; }
    .nav-inner { grid-template-columns: auto auto; }
  }
</style>
<script>
  // Wire command-palette open button to the island's custom event.
  document.getElementById('cmdk-open')?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('realms:cmdk-open'));
  });
</script>
