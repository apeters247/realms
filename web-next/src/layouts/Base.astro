---
import '../styles/base.css';
import '../styles/layout.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  jsonLd?: unknown;
}

const {
  title,
  description = 'REALMS — a provenance-tracked knowledge base of spiritual entities documented across global traditions.',
  canonical,
  ogImage,
  noindex = false,
  jsonLd,
} = Astro.props;

const site = Astro.site ?? new URL('http://127.0.0.1:8005');
const canonicalUrl = new URL(canonical ?? Astro.url.pathname, site).toString();
// OG images: prefer the dynamic /og/entity/{id}.png endpoint (Pillow-rendered)
// but fall back to the bundled /app/og/default.svg for static pages.
const ogImageUrl = ogImage
  ? (ogImage.startsWith('http') ? ogImage : new URL(ogImage, site).toString())
  : new URL(`${import.meta.env.BASE_URL}og/default.svg`, site).toString();
const snapshotAt = new Date().toISOString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title} — REALMS</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="realms-snapshot-at" content={snapshotAt} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} — REALMS`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="REALMS" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} — REALMS`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="sitemap" href={`${import.meta.env.BASE_URL}sitemap-index.xml`} />
    <link rel="alternate" type="application/rss+xml" title="REALMS — recent entities" href={`${import.meta.env.BASE_URL}feed.xml`} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />

    {jsonLd && Array.isArray(jsonLd)
      ? jsonLd.map(entry => (
          <script type="application/ld+json" set:html={JSON.stringify(entry)} />
        ))
      : jsonLd && (
          <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
        )}

    <script is:inline>
      // Theme boot — read cookie/localStorage before paint.
      (() => {
        try {
          const key = 'realms.theme';
          const stored = localStorage.getItem(key);
          if (stored === 'dark' || stored === 'light') {
            document.documentElement.setAttribute('data-theme', stored);
          }
          const rk = 'realms.researcher';
          if (localStorage.getItem(rk) === 'true') {
            document.documentElement.setAttribute('data-researcher', 'true');
          }
        } catch (e) { /* storage blocked */ }
      })();
    </script>
  </head>
  <body>
    <a class="skip-link ui" href="#main">Skip to content</a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
<style>
  main {
    display: block;
    min-height: 60vh;
  }
</style>
