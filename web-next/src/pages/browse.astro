---
import Base from '../layouts/Base.astro';
import HoverPreview from '../islands/HoverPreview.svelte';
import Breadcrumb from '../components/Breadcrumb.astro';
import BrowseList from '../islands/BrowseList.svelte';
import { loadSnapshot } from '../lib/loader';

const snap = await loadSnapshot();

// For SEO / crawlers: emit a compact hidden <noscript> list of every
// entity name + link. JS-enabled clients get the interactive BrowseList.
---
<Base title="Browse" description="Complete index of REALMS entities — filter by type, tradition, realm, and confidence." canonical="/browse/">
  <HoverPreview client:idle />
  <div class="page">
    <Breadcrumb items={[{ label: 'Browse' }]} />
    <h1>Browse the archive</h1>
    <p class="subtitle">
      {snap.entities.length.toLocaleString()} entities. Filter by type, tradition,
      realm, or confidence. Search by name.
    </p>

    <BrowseList client:load />

    <noscript>
      <p class="noscript-note">
        JavaScript is off. Open the
        <a href="/search-index.json">raw index</a> or the
        <a href="/export/entities.json">dataset dump</a>.
      </p>
    </noscript>
  </div>
</Base>

<style>
  h1 { font-size: var(--fs-3xl); font-weight: 450; margin-bottom: var(--sp-2); }
  .subtitle {
    color: var(--ink-dim);
    max-width: var(--col-prose);
    margin-bottom: var(--sp-4);
  }
  .noscript-note {
    color: var(--ink-faint);
    font-size: var(--fs-sm);
    padding: var(--sp-4);
    background: var(--bg-alt);
    border-radius: var(--r-md);
  }
</style>
