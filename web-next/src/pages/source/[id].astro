---
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import HoverPreview from '../../islands/HoverPreview.svelte';
import { loadSnapshot } from '../../lib/loader';
import { api, apiAll } from '../../lib/api';
import { url } from '../../lib/url';

interface SourceDetail {
  id: number;
  source_type: string;
  source_name: string;
  authors: Array<{ name: string; affiliation?: string | null }> | null;
  publication_year: number | null;
  journal_or_venue: string | null;
  doi: string | null;
  isbn: string | null;
  url: string | null;
  peer_reviewed: boolean | null;
  credibility_score: number | null;
  language: string | null;
  ingestion_status: string;
  processed_at: string | null;
  ingested_entities: Array<{
    id: number;
    entity_name_normalized: string;
    extraction_confidence: number;
    status: string;
  }>;
  extraction_statistics: { count: number; avg_confidence: number };
}

export async function getStaticPaths() {
  let sources: Array<{ id: number }> = [];
  try {
    sources = await apiAll<{ id: number }>('/sources/', 100);
  } catch (err) {
    console.warn(`[source/[id]] getStaticPaths failed:`, err);
  }
  return sources.map(s => ({ params: { id: String(s.id) }, props: { id: s.id } }));
}

const { id } = Astro.props as { id: number };
let source: SourceDetail | null = null;
try {
  const resp = await api<{ data: SourceDetail }>(`/sources/${id}`);
  source = resp.data;
} catch {
  /* fall through; render "not found" */
}

const snap = await loadSnapshot();
const canonicalPath = `/source/${id}`;
const title = source?.source_name ?? `Source #${id}`;
const description = source
  ? `${source.source_type} source cited in REALMS. ${source.extraction_statistics.count} entities extracted.`
  : `Source #${id}`;

// Resolve each ingested-entity name to a public slug where possible.
function resolveEntityLink(name: string): { href: string | null; id: number | null } {
  for (const [slug, e] of Object.entries(snap.entityBySlug)) {
    if (e.name?.toLowerCase() === name.toLowerCase()) {
      return { href: url(`/entity/${slug}/`), id: e.id };
    }
  }
  return { href: null, id: null };
}

const statusColor: Record<string, string> = {
  completed: 'var(--conf-high)',
  processing: 'var(--accent-2)',
  pending: 'var(--ink-faint)',
  failed: 'var(--conf-low)',
};
---
<Base title={title} description={description} canonical={canonicalPath}>
  <HoverPreview client:idle />
  <div class="page">
    <Breadcrumb
      items={[
        { label: 'Sources', href: url('/sources/') },
        { label: source ? source.source_name : `#${id}` },
      ]}
    />

    {source ? (
      <article>
        <header class="header">
          <div class="source-type ui">{source.source_type}</div>
          <h1>{source.source_name}</h1>
          {source.authors && source.authors.length > 0 && (
            <p class="authors">
              {source.authors.map((a, i) => (
                <>
                  {i > 0 && ', '}
                  <span>{a.name}</span>
                  {a.affiliation && <span class="affil"> ({a.affiliation})</span>}
                </>
              ))}
            </p>
          )}
          {source.publication_year && (
            <p class="pubinfo ui">
              {source.publication_year}
              {source.journal_or_venue && ` · ${source.journal_or_venue}`}
              {source.language && ` · ${source.language}`}
            </p>
          )}
        </header>

        <section class="sidenotes">
          <dl>
            <div>
              <dt>Status</dt>
              <dd style={`color:${statusColor[source.ingestion_status] || 'var(--ink-dim)'}`}>{source.ingestion_status}</dd>
            </div>
            {source.processed_at && (
              <div>
                <dt>Processed</dt>
                <dd class="mono">{source.processed_at.slice(0, 10)}</dd>
              </div>
            )}
            {source.peer_reviewed !== null && (
              <div>
                <dt>Peer reviewed</dt>
                <dd>{source.peer_reviewed ? 'Yes' : 'No'}</dd>
              </div>
            )}
            {source.credibility_score !== null && (
              <div>
                <dt>Credibility</dt>
                <dd class="mono">{Number(source.credibility_score).toFixed(2)}</dd>
              </div>
            )}
            {source.doi && (
              <div>
                <dt>DOI</dt>
                <dd class="mono"><a href={`https://doi.org/${source.doi}`} rel="noopener">{source.doi}</a></dd>
              </div>
            )}
            {source.isbn && (
              <div>
                <dt>ISBN</dt>
                <dd class="mono">{source.isbn}</dd>
              </div>
            )}
            {source.url && (
              <div>
                <dt>URL</dt>
                <dd><a href={source.url} rel="noopener" target="_blank">{new URL(source.url).hostname}</a></dd>
              </div>
            )}
          </dl>
        </section>

        <section class="extractions">
          <h2>Entities extracted <span class="n ui">· {source.extraction_statistics.count}</span></h2>
          {source.extraction_statistics.count > 0 ? (
            <>
              <p class="caption">
                Average extraction confidence
                <span class="mono">{Number(source.extraction_statistics.avg_confidence).toFixed(2)}</span>.
              </p>
              <ol class="ents">
                {source.ingested_entities.map(ent => {
                  const link = resolveEntityLink(ent.entity_name_normalized);
                  return (
                    <li>
                      {link.href ? (
                        <a href={link.href} data-preview={link.id}>{ent.entity_name_normalized}</a>
                      ) : (
                        <span>{ent.entity_name_normalized}</span>
                      )}
                      <span class="conf mono">{Number(ent.extraction_confidence).toFixed(2)}</span>
                      <span class="status ui">{ent.status}</span>
                    </li>
                  );
                })}
              </ol>
            </>
          ) : (
            <p class="muted">No entities extracted from this source yet.</p>
          )}
        </section>
      </article>
    ) : (
      <p class="muted">Source #{id} not found.</p>
    )}
  </div>
</Base>

<style>
  .header { padding-bottom: var(--sp-4); border-bottom: 1px solid var(--rule); margin-bottom: var(--sp-5); }
  .source-type {
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: var(--fs-xs);
    color: var(--ink-faint);
    margin-bottom: var(--sp-2);
  }
  h1 {
    font-size: var(--fs-3xl);
    font-weight: 450;
    line-height: 1.15;
    margin: 0 0 var(--sp-3) 0;
    max-width: var(--col-prose);
  }
  .authors { color: var(--ink-dim); font-size: var(--fs-md); margin: 0 0 var(--sp-2) 0; }
  .authors .affil { color: var(--ink-faint); font-size: var(--fs-sm); }
  .pubinfo { color: var(--ink-faint); font-size: var(--fs-sm); margin: 0; }
  .sidenotes { margin-bottom: var(--sp-6); }
  .sidenotes dl {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: var(--sp-3) var(--sp-5);
    padding: var(--sp-3) 0;
    border-top: 1px solid var(--rule-soft);
    border-bottom: 1px solid var(--rule-soft);
    margin: 0;
  }
  .sidenotes dt {
    font-family: var(--font-sans);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-faint);
    margin-bottom: 2px;
  }
  .sidenotes dd {
    margin: 0;
    font-size: var(--fs-sm);
    color: var(--ink);
  }
  .mono { font-family: var(--font-mono); }
  h2 {
    font-size: var(--fs-lg);
    font-weight: 450;
    margin: 0 0 var(--sp-3) 0;
  }
  h2 .n { color: var(--ink-faint); font-size: var(--fs-sm); font-weight: normal; }
  .caption { color: var(--ink-dim); font-size: var(--fs-sm); margin: 0 0 var(--sp-3) 0; }
  .caption .mono { margin-left: 4px; color: var(--ink); }
  .ents {
    list-style: none;
    padding: 0;
    margin: 0;
    max-width: var(--col-prose);
  }
  .ents li {
    display: flex;
    gap: var(--sp-3);
    align-items: baseline;
    padding: var(--sp-2) 0;
    border-bottom: 1px solid var(--rule-soft);
  }
  .ents a { color: var(--ink); text-decoration: none; }
  .ents a:hover { color: var(--accent); text-decoration: underline; }
  .ents .conf { color: var(--ink-faint); font-size: var(--fs-sm); margin-left: auto; }
  .ents .status { color: var(--ink-faint); font-size: var(--fs-xs); text-transform: uppercase; letter-spacing: 0.08em; }
  .muted { color: var(--ink-faint); }
</style>
