---
import Base from '../layouts/Base.astro';
import EntityCard from '../components/EntityCard.astro';
import HoverPreview from '../islands/HoverPreview.svelte';
import { loadSnapshot } from '../lib/loader';
import { websiteJsonLd } from '../lib/jsonld';
import { api } from '../lib/api';
import { url } from '../lib/url';
import CoverageBar from '../components/CoverageBar.astro';

const snap = await loadSnapshot();
const site = Astro.site ?? new URL('http://127.0.0.1:8004');

// Recent = last ~12 entities by id (our proxy for ingestion order; the
// listing endpoint doesn't return description text so we don't filter on it).
const recent = snap.entities
  .slice()
  .sort((a, b) => b.id - a.id)
  .slice(0, 12);

// Best-documented sample — high consensus, has cultural associations — for a
// "start here" strip on the home page.
const showcase = snap.entities
  .filter(e => (e.consensus_confidence ?? 0) >= 0.85 && (e.cultural_associations || []).length > 0)
  .sort((a, b) => (b.consensus_confidence ?? 0) - (a.consensus_confidence ?? 0))
  .slice(0, 8);

// Featured traditions: pick the 12 with the most member entities.
const traditionCount = new Map<string, number>();
for (const e of snap.entities) {
  for (const c of (e.cultural_associations || [])) {
    traditionCount.set(c, (traditionCount.get(c) || 0) + 1);
  }
}
const topTraditions = [...traditionCount.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 12);

// Total distinct tradition strings (from snapshot traditions table + from
// entity cultural_associations) — shows a more honest "coverage" number.
const traditionUnion = new Set<string>(
  [...snap.traditions.map(t => t.name), ...traditionCount.keys()],
);
const regionUnion = new Set<string>([
  ...snap.regions.map(r => r.name),
  ...snap.entities.flatMap(e => e.geographical_associations || []),
]);

// Global stats from the /stats endpoint (best-effort).
let stats: any = null;
try {
  const s = await api<{ data: any }>('/stats/');
  stats = s.data;
} catch { /* ignore */ }

// Corroboration summary (tier counts).
let tiers: any = null;
try {
  const s = await api<{ data: any }>('/corroboration/stats/summary');
  tiers = s.data;
} catch { /* ignore */ }

const jsonLd = websiteJsonLd(site.toString());
---
<Base title="Archive of entities" canonical="/" jsonLd={jsonLd}>
  <HoverPreview client:idle />

  <section class="page hero">
    <h1 class="display">
      An archive of the spiritual entities humans have documented.
    </h1>
    <p class="subtitle">
      Every claim traces to a source. Every source traces to a text.
      Browse {snap.entities.length.toLocaleString()} entities across {traditionUnion.size} traditions
      and {regionUnion.size} regions.
    </p>
    <div class="hero-actions ui">
      <a class="btn primary" href={url('/browse/')}>Browse the archive →</a>
      <a class="btn secondary" href={url('/graph/')}>Explore the graph</a>
      <a class="btn secondary" href={url('/about/methodology/')}>How we gathered this</a>
    </div>
  </section>

  <section class="page stats">
    <div class="stat">
      <div class="n">{snap.entities.length.toLocaleString()}</div>
      <div class="label">entities</div>
    </div>
    <div class="stat">
      <div class="n">{traditionUnion.size.toLocaleString()}</div>
      <div class="label">traditions</div>
    </div>
    <div class="stat">
      <div class="n">{regionUnion.size.toLocaleString()}</div>
      <div class="label">regions</div>
    </div>
    {stats?.total_relationships != null && (
      <div class="stat">
        <div class="n">{Number(stats.total_relationships).toLocaleString()}</div>
        <div class="label">relationships</div>
      </div>
    )}
    {tiers?.tier_counts && (
      <div class="stat">
        <div class="n">{(tiers.tier_counts.tier_2 || 0) + (tiers.tier_counts.tier_3 || 0)}</div>
        <div class="label">corroborated</div>
      </div>
    )}
  </section>

  {tiers?.tier_counts && (
    <section class="page coverage-section">
      <div class="coverage-head">
        <div>
          <p class="label">Provenance coverage</p>
          <p class="sub">How many distinct source types back each entity.</p>
        </div>
        <a class="more ui" href={url('/about/methodology/')}>What does this mean? →</a>
      </div>
      <CoverageBar tiers={tiers.tier_counts} />
    </section>
  )}

  <section class="page">
    <div class="section-head">
      <h2>Featured entries</h2>
      <a class="more ui" href={url('/browse/')}>Browse all →</a>
    </div>
    <div class="card-grid">
      {showcase.map(e => (
        <EntityCard entity={e} slug={snap.entitySlugById[e.id]} />
      ))}
    </div>
  </section>

  <section class="page">
    <div class="section-head">
      <h2>Recently added</h2>
      <a class="more ui" href={url('/browse/')}>Browse by type →</a>
    </div>
    <ol class="recent-list">
      {recent.map(e => (
        <li>
          <a href={url(`/entity/${snap.entitySlugById[e.id]}/`)} data-preview={e.id}>
            <span class="r-name">{e.name}</span>
            <span class="r-meta ui">
              {e.entity_type && <span>{e.entity_type}</span>}
              {(e.cultural_associations || [])[0] && <span> · {(e.cultural_associations || [])[0]}</span>}
            </span>
          </a>
        </li>
      ))}
    </ol>
  </section>

  {topTraditions.length > 0 && (
    <section class="page">
      <div class="section-head">
        <h2>Traditions</h2>
      </div>
      <div class="trad-grid">
        {topTraditions.map(([name, n]) => {
          const slug = name.normalize('NFD').replace(/[\u0300-\u036f]/g, '')
            .toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
          return (
            <a class="trad" href={url(`/tradition/${slug}/`)}>
              <span class="trad-name">{name}</span>
              <span class="trad-count ui">{n}</span>
            </a>
          );
        })}
      </div>
    </section>
  )}

  <section class="page methodology-note">
    <div class="note">
      <p class="ui label">Why provenance matters</p>
      <p class="body">
        REALMS is not a generative system. Every entity in the archive was extracted
        from a named source text by a pipeline whose exact model, temperature, and
        prompt version are recorded alongside the result. Where a description is
        compressed from multiple sources we mark it explicitly.
        <a href={url('/about/methodology/')}>Read the methodology →</a>
      </p>
    </div>
  </section>
</Base>

<style>
  .hero {
    padding-top: var(--sp-8);
    padding-bottom: var(--sp-8);
    max-width: calc(var(--col-prose) + var(--sp-8));
    margin: 0 auto;
  }
  .display {
    font-size: clamp(2.25rem, 4.8vw, 3.75rem);
    line-height: 1.05;
    letter-spacing: -0.025em;
    font-variation-settings: 'opsz' 144, 'SOFT' 40, 'WONK' 0;
    font-weight: 450;
    margin-bottom: var(--sp-5);
  }
  .subtitle {
    font-size: var(--fs-md);
    color: var(--ink-dim);
    line-height: var(--lh-loose);
    max-width: 56ch;
    margin-bottom: var(--sp-6);
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    font-size: var(--fs-sm);
  }
  .btn {
    text-decoration: none;
    padding: var(--sp-2) var(--sp-4);
    border-radius: var(--r-md);
    transition: all var(--dur-fast) var(--ease);
    border: 1px solid var(--rule);
  }
  .btn.primary {
    background: var(--accent);
    color: var(--bg);
    border-color: var(--accent);
  }
  .btn.primary:hover { background: var(--accent-soft); }
  .btn.secondary {
    color: var(--ink-dim);
    background: transparent;
  }
  .btn.secondary:hover { color: var(--ink); border-color: var(--ink-faint); }

  .stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: var(--sp-5);
    padding-top: var(--sp-4);
    padding-bottom: var(--sp-6);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }
  .stat .n {
    font-family: var(--font-serif);
    font-size: var(--fs-3xl);
    font-variation-settings: 'opsz' 72, 'SOFT' 40;
    line-height: 1;
    color: var(--ink);
  }
  .stat .label {
    margin-top: var(--sp-2);
    color: var(--ink-faint);
  }

  .coverage-section { padding-top: 0; }
  .coverage-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: var(--sp-5);
    margin-bottom: var(--sp-2);
  }
  .coverage-head .label { margin-bottom: 2px; }
  .coverage-head .sub {
    color: var(--ink-dim);
    font-size: var(--fs-sm);
    margin: 0;
  }

  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    border-bottom: 1px solid var(--rule);
    padding-bottom: var(--sp-2);
    margin-bottom: 0;
  }
  .section-head h2 {
    margin: 0;
    font-size: var(--fs-xl);
    font-variation-settings: 'opsz' 72, 'SOFT' 40;
    font-weight: 500;
  }
  .more {
    color: var(--ink-dim);
    text-decoration: none;
    font-size: var(--fs-sm);
  }
  .more:hover { color: var(--ink); }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 0;
    border-bottom: 1px solid var(--rule-soft);
  }
  .card-grid > * {
    border-right: 1px solid var(--rule-soft);
  }

  .trad-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    margin-top: var(--sp-4);
  }
  .trad {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: var(--sp-3) var(--sp-4);
    border-bottom: 1px solid var(--rule-soft);
    text-decoration: none;
    color: var(--ink);
    transition: background var(--dur-fast) var(--ease);
  }
  .trad:hover { background: var(--bg-alt); }
  .trad-name {
    font-family: var(--font-serif);
    font-size: var(--fs-md);
  }
  .trad-count {
    color: var(--ink-faint);
    font-size: var(--fs-xs);
    font-variant-numeric: tabular-nums;
  }

  .recent-list {
    list-style: none;
    padding: 0;
    margin: var(--sp-3) 0 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    column-gap: var(--sp-5);
  }
  .recent-list li {
    border-bottom: 1px solid var(--rule-soft);
  }
  .recent-list a {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--sp-3);
    padding: var(--sp-2) 0;
    text-decoration: none;
    color: var(--ink);
  }
  .recent-list a:hover {
    background: linear-gradient(to right, var(--bg-alt), transparent 30%);
  }
  .r-name {
    font-family: var(--font-serif);
    font-size: var(--fs-md);
  }
  .r-meta {
    color: var(--ink-faint);
    font-size: var(--fs-xs);
    text-align: right;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .methodology-note {
    max-width: calc(var(--col-prose) + var(--sp-8));
    margin: var(--sp-7) auto 0;
  }
  .note {
    padding: var(--sp-5) var(--sp-6);
    border-left: 2px solid var(--accent);
    background: var(--bg-alt);
    border-radius: 0 var(--r-md) var(--r-md) 0;
  }
  .note .label { margin-bottom: var(--sp-2); }
  .note .body {
    margin: 0;
    font-size: var(--fs-base);
    color: var(--ink-dim);
    max-width: 68ch;
  }
</style>
