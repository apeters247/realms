---
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import EntityCard from '../../components/EntityCard.astro';
import HoverPreview from '../../islands/HoverPreview.svelte';
import { loadSnapshot } from '../../lib/loader';
import { slugify } from '../../lib/slug';
import { url } from '../../lib/url';

export async function getStaticPaths() {
  const snap = await loadSnapshot();
  // Collect all culture strings we've seen across entities, not only rows
  // in the `cultures` table — tradition pages should exist for everything
  // readers can click from an entity.
  const names = new Set<string>();
  for (const e of snap.entities) {
    for (const c of (e.cultural_associations || [])) names.add(c);
  }
  for (const t of snap.traditions) names.add(t.name);
  const out: Array<{ params: { slug: string }; props: { name: string } }> = [];
  const seen = new Set<string>();
  for (const n of names) {
    const s = slugify(n);
    if (!s || seen.has(s)) continue;
    seen.add(s);
    out.push({ params: { slug: s }, props: { name: n } });
  }
  return out;
}

const { name } = Astro.props as { name: string };
const snap = await loadSnapshot();
const tradition = snap.traditions.find(t => slugify(t.name) === slugify(name)) || null;

const members = snap.entities.filter(e =>
  (e.cultural_associations || []).some(c => slugify(String(c)) === slugify(name))
);
members.sort((a, b) => (b.consensus_confidence || 0) - (a.consensus_confidence || 0));
---
<Base
  title={name}
  description={`Entities documented within the ${name} tradition.`}
  canonical={`/tradition/${slugify(name)}`}
>
  <HoverPreview client:idle />
  <div class="page">
    <Breadcrumb items={[{ label: 'Browse', href: url('/browse/') }, { label: name }]} />
    <h1>{name}</h1>
    {tradition?.tradition_type && <div class="sub ui">{tradition.tradition_type}</div>}
    {tradition?.description && <p class="descr">{tradition.description}</p>}

    <div class="meta-row ui">
      <span>{members.length} {members.length === 1 ? 'entity' : 'entities'}</span>
      {tradition?.region && <span>· {tradition.region}</span>}
      {tradition?.language_family && <span>· {tradition.language_family}</span>}
    </div>

    <div class="col-list">
      {members.map(m => (
        <EntityCard entity={m} slug={snap.entitySlugById[m.id]} />
      ))}
    </div>
  </div>
</Base>

<style>
  h1 {
    font-size: var(--fs-3xl);
    font-weight: 450;
    margin-bottom: 0;
  }
  .sub {
    color: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--fs-xs);
    margin-bottom: var(--sp-4);
  }
  .descr {
    max-width: var(--col-prose);
    color: var(--ink-dim);
    font-size: var(--fs-md);
    line-height: var(--lh-loose);
  }
  .meta-row {
    display: flex;
    gap: var(--sp-2);
    color: var(--ink-faint);
    font-size: var(--fs-sm);
    padding: var(--sp-3) 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    margin-bottom: var(--sp-5);
  }
  .col-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    border-bottom: 1px solid var(--rule-soft);
  }
</style>
