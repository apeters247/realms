---
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import EntityCard from '../../components/EntityCard.astro';
import HoverPreview from '../../islands/HoverPreview.svelte';
import { api } from '../../lib/api';
import { loadSnapshot } from '../../lib/loader';
import { slugify } from '../../lib/slug';
import { url } from '../../lib/url';

interface CollectionDetail {
  slug: string;
  title: string;
  subtitle: string;
  description: string;
  n_members: number;
  members: Array<{
    id: number; name: string; entity_type: string | null;
    alignment: string | null; realm: string | null;
    consensus_confidence: number;
    cultural_associations: string[];
  }>;
}

export async function getStaticPaths() {
  let slugs: string[] = [];
  try {
    const r = await api<{ data: Array<{ slug: string }> }>('/collections/');
    slugs = (r.data || []).map(c => c.slug);
  } catch { /* tolerate empty builds */ }
  return slugs.map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params as { slug: string };
let detail: CollectionDetail | null = null;
try {
  const r = await api<{ data: CollectionDetail }>(`/collections/${slug}`);
  detail = r.data;
} catch { /* not found */ }

const snap = await loadSnapshot();

function entitySlugFor(id: number, name: string): string {
  return snap.entitySlugById[id] ?? slugify(name);
}
---
<Base
  title={detail ? detail.title : slug}
  description={detail?.subtitle ?? 'A curated collection of entities.'}
  canonical={`/collection/${slug}`}
>
  <HoverPreview client:idle />
  <div class="page">
    <Breadcrumb items={[
      { label: 'Collections', href: url('/collections/') },
      { label: detail?.title ?? slug },
    ]} />

    {detail ? (
      <article>
        <header class="hd">
          <h1>{detail.title}</h1>
          <p class="sub ui">{detail.subtitle}</p>
          <p class="desc">{detail.description}</p>
          <p class="count ui">{detail.n_members} entities</p>
        </header>

        <section class="members">
          {detail.members.map(m => (
            <EntityCard
              entity={{
                id: m.id, name: m.name, entity_type: m.entity_type,
                alignment: m.alignment, realm: m.realm,
                consensus_confidence: m.consensus_confidence,
                cultural_associations: m.cultural_associations,
              }}
              slug={entitySlugFor(m.id, m.name)}
            />
          ))}
        </section>
      </article>
    ) : (
      <p class="muted">Collection <code>{slug}</code> not found.</p>
    )}
  </div>
</Base>

<style>
  .hd { padding-bottom: var(--sp-4); border-bottom: 1px solid var(--rule); margin-bottom: var(--sp-5); }
  h1 {
    font-size: var(--fs-3xl);
    font-weight: 450;
    margin: 0 0 var(--sp-2) 0;
  }
  .sub {
    color: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--fs-xs);
    margin: 0 0 var(--sp-3) 0;
  }
  .desc {
    max-width: var(--col-prose);
    color: var(--ink-dim);
    line-height: var(--lh-loose);
    margin: 0 0 var(--sp-3) 0;
  }
  .count {
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0;
  }
  .members {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    border-bottom: 1px solid var(--rule-soft);
  }
  .muted { color: var(--ink-faint); }
  code { font-family: var(--font-mono); font-size: var(--fs-sm); }
</style>
