---
import Base from '../layouts/Base.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { api } from '../lib/api';
import { url } from '../lib/url';

interface Week {
  week: string;
  entities: Array<{ id: number; name: string }>;
  sources: Array<{ id: number; name: string; type: string }>;
  relationships: number;
  integrity_audits: Array<{ id: number; sample_size: number; error_rate: number; oracle_model: string }>;
  entity_count?: number;
  source_count?: number;
}

let weeks: Week[] = [];
try {
  const r = await api<{ data: Week[] }>('/changelog/?weeks=26');
  weeks = r.data || [];
} catch { /* tolerate */ }

function slugify(name: string): string {
  return (name || '').normalize('NFD').replace(/[\u0300-\u036f]/g, '')
    .toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
}
---
<Base
  title="Changelog"
  description="Weekly activity log: new entities, new sources, integrity audits. RSS feed available."
  canonical="/changelog"
>
  <div class="page">
    <Breadcrumb items={[{ label: 'Changelog' }]} />
    <h1>Changelog</h1>
    <p class="subtitle">
      A public log of what entered or moved in the archive each week.
      Subscribe via <a href={url('/changelog.rss')}>RSS</a>.
    </p>

    {weeks.length === 0 && (
      <p class="empty ui">No activity recorded yet.</p>
    )}

    {weeks.map(w => (
      <section class="week" id={w.week}>
        <header>
          <h2>{w.week}</h2>
          <div class="totals ui">
            <span>{w.entity_count ?? w.entities.length} new entities</span>
            {w.source_count && <span>· {w.source_count} new sources</span>}
            {w.relationships > 0 && <span>· {w.relationships} new relationships</span>}
            {w.integrity_audits.length > 0 && <span>· {w.integrity_audits.length} integrity audits</span>}
          </div>
        </header>

        {w.entities.length > 0 && (
          <div class="block">
            <h3>New entities</h3>
            <ul class="entities">
              {w.entities.map(e => (
                <li><a href={url(`/entity/${slugify(e.name)}/`)} data-preview={e.id}>{e.name}</a></li>
              ))}
            </ul>
          </div>
        )}

        {w.sources.length > 0 && (
          <div class="block">
            <h3>Ingested sources</h3>
            <ul class="sources">
              {w.sources.map(s => (
                <li>
                  <a href={url(`/source/${s.id}/`)}>{s.name}</a>
                  <span class="type ui">{s.type}</span>
                </li>
              ))}
            </ul>
          </div>
        )}

        {w.integrity_audits.length > 0 && (
          <div class="block">
            <h3>Integrity audits</h3>
            <ul class="audits">
              {w.integrity_audits.map(a => (
                <li>
                  <span class="mono">{a.sample_size} samples</span>
                  <span class="er">error rate {(a.error_rate * 100).toFixed(1)}%</span>
                  <span class="ui muted">{a.oracle_model}</span>
                </li>
              ))}
            </ul>
          </div>
        )}
      </section>
    ))}
  </div>
</Base>

<style>
  h1 { font-size: var(--fs-3xl); font-weight: 450; margin-bottom: var(--sp-2); }
  .subtitle { color: var(--ink-dim); max-width: var(--col-prose); margin-bottom: var(--sp-6); }
  .subtitle a { color: var(--accent-2); }
  .week { margin-bottom: var(--sp-7); border-top: 1px solid var(--rule); padding-top: var(--sp-4); }
  .week header { margin-bottom: var(--sp-3); }
  .week h2 {
    font-family: var(--font-mono);
    font-size: var(--fs-xl);
    color: var(--ink);
    margin: 0 0 var(--sp-2) 0;
    font-weight: 450;
  }
  .totals {
    color: var(--ink-faint);
    font-size: var(--fs-sm);
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .block { margin-bottom: var(--sp-4); }
  .block h3 {
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-faint);
    margin: 0 0 var(--sp-2) 0;
  }
  .entities, .sources, .audits {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2) var(--sp-3);
  }
  .entities li { font-family: var(--font-serif); font-size: var(--fs-sm); }
  .entities a { color: var(--ink); text-decoration: none; }
  .entities a:hover { color: var(--accent); text-decoration: underline; }
  .sources li { display: flex; align-items: baseline; gap: 6px; font-size: var(--fs-sm); }
  .sources a { color: var(--ink); text-decoration: none; }
  .sources a:hover { color: var(--accent); text-decoration: underline; }
  .sources .type { color: var(--ink-faint); font-size: var(--fs-xs); text-transform: uppercase; letter-spacing: 0.08em; }
  .audits { flex-direction: column; gap: var(--sp-2); }
  .audits li { display: flex; gap: var(--sp-3); font-size: var(--fs-sm); color: var(--ink-dim); }
  .mono { font-family: var(--font-mono); }
  .er { color: var(--conf-high); }
  .muted { color: var(--ink-faint); }
  .empty { color: var(--ink-faint); }
</style>
